@startuml
title Login de Usuário

start

:Usuário acessa o sistema;

repeat
  :Informa e-mail e senha;

  if (Campos preenchidos?) then (Sim)
    :Sistema valida credenciais;

    if (Credenciais válidas?) then (Sim)
      :Sistema libera acesso;
      :Usuário acessa o painel financeiro;
    else (Não)
      :Sistema exibe mensagem de erro;
    endif

  else (Não)
    :Sistema solicita preenchimento dos campos;
  endif

repeat while (Credenciais válidas?) is (Não)
-> Sim;

stop
@enduml
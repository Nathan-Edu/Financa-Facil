@startuml
title Gerenciar Usuários

start

:Administrador acessa o sistema;
:Seleciona gerenciamento de usuários;
:Sistema lista usuários cadastrados;
:Administrador seleciona usuário;

if (Editar usuário?) then (Sim)

  repeat
    :Administrador altera informações;

    if (Dados válidos?) then (Sim)
      :Sistema atualiza cadastro;
    else (Não)
      :Sistema exibe mensagem de erro;
    endif

  repeat while (Dados válidos?) is (Não)
  -> Sim;

else (Não)
  if (Excluir usuário?) then (Sim)
    :Administrador confirma exclusão;

    if (Confirmação válida?) then (Sim)
      :Sistema remove usuário;
    else (Não)
      :Sistema cancela operação;
    endif

  else (Consultar)
@startuml
title Gerar Relatório Financeiro

start

:Usuário acessa relatórios;

repeat
  :Seleciona período e tipo de relatório;

  if (Filtros válidos?) then (Sim)
    :Sistema consulta movimentações;
    :Sistema organiza dados financeiros;
    :Sistema gera gráficos e resumo;
    :Sistema exibe relatório;
  else (Não)
    :Sistema solicita ajuste dos filtros;
  endif

repeat while (Filtros válidos?) is (Não)
-> Sim;

stop
@enduml